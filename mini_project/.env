# X (Twitter) API — https://developer.x.com/en/portal/dashboard
# Tweepy auth guide: https://docs.tweepy.org/en/stable/authentication.html

# App-only bearer token (required unless using OAuth below)
TWITTER_BEARER_TOKEN=your_bearer_token_here

# OAuth 1.0a user context (recommended — better access to view/impression metrics)
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: model override (defaults to gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
